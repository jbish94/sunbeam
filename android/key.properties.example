# Android release signing configuration
#
# 1. Generate the upload keystore ONCE on your build machine (keep it
#    somewhere safe and backed up — losing it means losing the ability
#    to update the app with the same key):
#
#    keytool -genkey -v -keystore ~/sunbeam-upload-keystore.jks \
#      -keyalg RSA -keysize 2048 -validity 10000 -alias upload
#
# 2. Copy this file to android/key.properties and fill in the values.
#    key.properties and *.jks are gitignored — NEVER commit them.
#
storePassword=YOUR_KEYSTORE_PASSWORD
keyPassword=YOUR_KEY_PASSWORD
keyAlias=upload
storeFile=/Users/you/sunbeam-upload-keystore.jks
